APP_NAME="Circuit Hackathon Backend"
APP_ENV=local
LOG_LEVEL=INFO
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=nvidia.nemotron-nano-12b-v2
BOM_EXTRACTION_PROMPT=Extract and list all the components from this schematic image of a hardware diagram. Return ONLY valid JSON array of objects with fields: refdes(optional), type, value, package(optional), qty(integer). No extra text.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=circuit-dev-password
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
# Optional. X-DIGIKEY-Account-Id is sent only when non-empty and not "0".
DIGIKEY_ACCOUNT_ID=
DIGIKEY_USE_SANDBOX=false
DIGIKEY_LOCALE_SITE=US
DIGIKEY_LOCALE_LANGUAGE=en
DIGIKEY_LOCALE_CURRENCY=USD
DIGIKEY_HTTP_TIMEOUT_S=20
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.5-highspeed
ENABLE_MINIMAX_NARRATOR=false
DD_SERVICE=circuit-backend
DD_ENV=local
DD_VERSION=0.1.0
DD_AGENT_HOST=localhost
DD_TRACE_ENABLED=false
DD_LOGS_INJECTION=true
