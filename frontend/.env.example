# Backend base URL (no trailing slash). Used by src/api.js for all /api/* calls.
VITE_API_BASE=http://localhost:8000

# CopilotKit runtime (sidebar). Fallback: http://localhost:8000/api/copilotkit
# VITE_COPILOT_RUNTIME_URL=http://localhost:8000/api/copilotkit

# Set to true or 1 to run without Copilot (app works without backend)
# VITE_DISABLE_COPILOT=true
